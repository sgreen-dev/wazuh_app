terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Provider cache — auto-generated, huge
.terraform/

# Sensitive variable files
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json